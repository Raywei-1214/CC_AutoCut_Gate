{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ChuangCut Local Upload Agent",
  "version": "0.1.0",
  "identifier": "com.shimi.chuangcut.local-upload-agent",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "创剪本地上传助手",
        "width": 960,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "创剪本地上传助手",
    "longDescription": "创剪本地上传助手安装版，负责在本地机器上稳定接管网页发起的大文件上传。"
  }
}
